# Backend chạy tại api.{domain}, route gốc /upload, /files (không prefix /api)
PORT=3001

# CORS: khi NODE_ENV=production chỉ chấp nhận origin trong CORS_ORIGIN (cách nhau dấu phẩy). Local không set NODE_ENV thì cho phép mọi origin.
# CORS_ORIGIN=https://xulyanh.online,https://www.xulyanh.online
CORS_ORIGIN=

# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=aws_user
DB_PASSWORD=aws_password
DB_NAME=aws_test_db

# AWS (server: IAM role; local: set AWS_ACCESS_KEY_ID + AWS_SECRET_ACCESS_KEY trong .env)
AWS_REGION=ap-southeast-1
AWS_S3_BUCKET=your-bucket-name
CDN_BASE_URL=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

SES_FROM=noreply@yourdomain.com
