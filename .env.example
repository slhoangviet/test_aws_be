# Backend chạy tại api.{domain}, route gốc /upload, /files (không prefix /api)
PORT=3000

# CORS: production nên whitelist domain FE (ví dụ S3/CloudFront), cách nhau bởi dấu phẩy
# Để trống = cho phép mọi origin (phù hợp dev)
# CORS_ORIGIN=https://yourdomain.com,https://www.yourdomain.com

# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=aws_user
DB_PASSWORD=aws_password
DB_NAME=aws_test_db

# AWS S3
AWS_REGION=ap-southeast-1
AWS_S3_BUCKET=your-bucket-name
# CDN base URL (nếu dùng CloudFront trước S3) để trả URL file cho client
# CDN_BASE_URL=https://d123.cloudfront.net

# AWS SES (gửi email qua API, dùng IAM credentials)
# Trên EC2/ECS: gán IAM role có quyền ses:SendEmail, ses:SendRawEmail.
# Local/dev: set AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY (cùng IAM user có quyền SES).
# Email "From" phải là identity đã verify trong SES
SES_FROM=noreply@yourdomain.com
