# Backend chạy tại api.{domain}, route gốc /upload, /files (không prefix /api)
PORT=3001

# CORS: production nên whitelist domain FE (ví dụ S3/CloudFront), cách nhau bởi dấu phẩy
# Để trống = cho phép mọi origin (phù hợp dev)
# CORS_ORIGIN=https://yourdomain.com,https://www.yourdomain.com

# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=aws_user
DB_PASSWORD=aws_password
DB_NAME=aws_test_db

# AWS (server: IAM role; local: set AWS_ACCESS_KEY_ID + AWS_SECRET_ACCESS_KEY trong .env)
AWS_REGION=ap-southeast-1
AWS_S3_BUCKET=your-bucket-name
CDN_BASE_URL=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

SES_FROM=noreply@yourdomain.com
