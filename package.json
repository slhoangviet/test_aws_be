    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "multer": "^1.4.5-lts.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@types/multer": "^1.4.12",
    "@types/node": "^22.10.2",
    "ts-node-dev": "^2.0.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.0"
  }
}
