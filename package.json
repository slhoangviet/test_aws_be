{
  "name": "test_aws_be",
  "version": "1.0.0",
  "description": "Basic NestJS backend for AWS test",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "start:dev": "ts-node-dev -r tsconfig-paths/register --respawn src/main.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.740.0",
